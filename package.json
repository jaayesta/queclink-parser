{
  "name": "queclink-parser",
  "version": "1.9.30",
  "description": "Parse raw data from Queclink devices",
  "main": "src",
  "scripts": {
    "lint": "eslint . --fix",
    "format": "prettier --write 'src/**/*.js' 'test/**/*.js'",
    "audit:critical": "npm audit --audit-level=critical",
    "pretest": "npm run lint -s && npm run format -s",
    "test": "nyc mocha",
    "release:major": "changelog -M && git add CHANGELOG.md && git commit -m 'updated CHANGELOG.md' && npm version major && git push origin && git push origin --tags && npm publish",
    "release:minor": "changelog -m && git add CHANGELOG.md && git commit -m 'updated CHANGELOG.md' && npm version minor && git push origin && git push origin --tags && npm publish",
    "release:patch": "changelog -p && git add CHANGELOG.md && git commit -m 'updated CHANGELOG.md' && npm version patch && git push origin && git push origin --tags && npm publish",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jaayesta/queclink-parser.git"
  },
  "keywords": [
    "queclink",
    "avl",
    "gps",
    "tracking",
    "parser"
  ],
  "author": "Jose Andres Ayestaran <ja.ayestaran@gmail.com>",
  "contributors": [
    {
      "name": "Leonardo Gatica",
      "email": "lgatica@protonmail.com",
      "url": "https://about.me/lgatica"
    }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jaayesta/queclink-parser/issues"
  },
  "homepage": "https://github.com/jaayesta/queclink-parser#readme",
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.5"
  },
  "devDependencies": {
    "chai": "^4.5.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.6.0",
    "generate-changelog": "^1.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "mocha": "^11.1.0",
    "nyc": "^17.1.0",
    "prettier": "^3.5.0"
  },
  "eslintConfig": {
    "extends": [
      "standard",
      "prettier"
    ],
    "rules": {
      "no-console": [
        "error"
      ]
    }
  },
  "eslintIgnore": [
    "coverage",
    "example.js"
  ],
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "test/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "tonicExampleFilename": "example.js",
  "renovate": {
    "automerge": "minor",
    "extends": [
      ":library"
    ]
  }
}
